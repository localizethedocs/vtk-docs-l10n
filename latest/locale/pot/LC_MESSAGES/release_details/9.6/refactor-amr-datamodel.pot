msgstr ""

#: ../../../release_details/9.6/refactor-amr-datamodel.md:59
msgid "Members:"
msgstr ""

#: ../../../release_details/9.6/refactor-amr-datamodel.md:61
msgid "vtkUniformGridAMR::Bounds is now private"
msgstr ""

#: ../../../release_details/9.6/refactor-amr-datamodel.md:63
msgid "Change of behavior:"
msgstr ""

#: ../../../release_details/9.6/refactor-amr-datamodel.md:65
msgid ""
"vtkUniformGridAMR::Initialize() now has multiple signatures, which may "
"require to specify the type of argument being provided."
msgstr ""

#: ../../../release_details/9.6/refactor-amr-datamodel.md:67
msgid ""
"vtkUniformGridAMR now inherits vtkPartitionedDataSetCollection, which means "
"any vtkPartitionedDataSetCollection::SafeDownCast(amr) will not return "
"nullptr anymore."
msgstr ""

#: ../../../release_details/9.6/refactor-amr-datamodel.md:70
msgid ""
"vtkUniformGridAMRIterator now inherits vtkDataObjectTreeIterator, which "
"means any vtkDataObjectTreeIterator::SafeDownCast(amrIter) will not return "
"nullptr anymore."
msgstr ""

#: ../../../release_details/9.6/refactor-amr-datamodel.md:73
msgid "vtkPlaneCutter now outputs a PDC instead of a MBD with a AMR input."
msgstr ""

#: ../../../release_details/9.6/refactor-amr-datamodel.md:75
msgid ""
"vtkDataObjectTree::CopyStructure(amr) used to reconstruct a data object tree "
"with an simili AMR structure, this is not the case anymore and it just copy "
"the partitioned dataset collection structure using the generic "
"implementation."
msgstr ""

#: ../../../release_details/9.6/refactor-amr-datamodel.md:78
msgid ""
"vtkUniformGridAMR::CopyStructure(amr) now copy the bounds as well to ensure "
"retro compatibility when dealing with vtkNonOverlappingAMR that do not "
"contains bounds in the vtkAMRMetaData, contrary to vtkOverlappingAMR."
msgstr ""

#: ../../../release_details/9.6/refactor-amr-datamodel.md:81
msgid ""
"vtkExtractBlockUsingDataAssembly now outputs a "
"vtkPartitionedDataSetCollection when input is a vtkNonOverlappingAMR for "
"consistency."
msgstr ""
