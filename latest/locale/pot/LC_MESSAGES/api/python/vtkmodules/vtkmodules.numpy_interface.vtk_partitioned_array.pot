msgid ""
"v / np.expand_dims(algs.mag(v), 1) VTKArray([[ 0.57735027,  0.57735027,  "
"0.57735027],        [ 0.57735027,  0.57735027,  0.57735027],        "
"[ 0.57735027,  0.57735027,  0.57735027],        [ 0.57735027,  0.57735027,  "
