"and outputs."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_partitioned_array.py:1008
msgid "For example:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_partitioned_array.py:1010
msgid "algs.where(algs.array([1,2,3]) == 2) (array([1]),)"
msgstr ""

