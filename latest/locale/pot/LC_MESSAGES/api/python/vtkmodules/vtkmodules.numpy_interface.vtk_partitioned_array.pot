msgid ""
"algs.where(algs.array([[1,2,3], [2,1,1]]) == 2) (array([0, 1]), array([1, "
"0]))"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_partitioned_array.py:1016
msgid ""
"a = array([[1,2,3], [2,1,1]]) indices = algs.where(a > 2) a[indices] "
"array([3])"
msgstr ""

