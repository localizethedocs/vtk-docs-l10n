msgid "Support for Blueprint implicit topology using point set"
msgstr ""

#: ../../../release_details/9.5/vtk-Catalyst-Implicit-Topology.md:3
msgid ""
"Catalyst Conduit now supports implicit topology (only points, no cells) "
"using point sets."
msgstr ""

