#: ../../../release_details/9.6/fix-Rendering_Matplotlib_image_null_pointer.md:3
msgid ""
"Some architectures (bigendian s390x) generate an image object with null "
"scalar pointer in vtkMatplotlibMathTextUtilities::RenderOneCell causing "
"segfaults. RenderOneCell() now returns false when a null pointer is found."
msgstr ""
