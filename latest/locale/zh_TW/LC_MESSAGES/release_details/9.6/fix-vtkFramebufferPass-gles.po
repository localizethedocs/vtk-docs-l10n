#: ../../../release_details/9.6/fix-vtkFramebufferPass-gles.md:1
msgid "vtkFramebufferPass GL_INVALID_OPERATION fix for GLES 3.0"
msgstr ""

#: ../../../release_details/9.6/fix-vtkFramebufferPass-gles.md:3
msgid ""
"You can now use vtkFramebufferPass in WebGL2 (GLES 3.0) without "
"GL_INVALID_OPERATION errors. It automatically detects when blitting to a "
"multisampled draw framebuffer and uses an alternative copy method to avoid "
"GL_INVALID_OPERATION errors."
msgstr ""
