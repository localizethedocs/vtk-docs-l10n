msgid "Enabling or Disabling Modules"
msgstr ""

#: ../../../modules/index.md:18
msgid "To enable a module set"
msgstr ""

#: ../../../modules/index.md:20
msgid "cmake -DVTK_MODULE_ENABLE_<module name>=WANT ...\n"
msgstr ""

