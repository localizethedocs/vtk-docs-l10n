#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:87
msgid ""
"``vtkStridedArray`` stores a strided view on a buffer, presenting "
"``buffer[stride * tupleIdx + offset + compIdx]`` as a virtual array. This "
"Python mixin adds numpy integration: arithmetic, reductions, indexing, and "
"``to_numpy()``."
msgstr ""

#: ../../../api/python/vtkmodules/vtkmodules.numpy_interface.vtk_strided_array.md:87
msgid "Initialization"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:91
msgid "Create a strided array."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:93
msgid "Can be called as::"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:95
msgid ""
"vtkStridedArray['float32']()                         # empty\n"
"vtkStridedArray['float32'](data, 2)                  # 1D, stride=2\n"
"vtkStridedArray['float32'](data_2d, 3)               # 2D, ncomps from "
"shape[1]\n"
"vtkStridedArray['float32'](data, 3, offset=1)        # with offset\n"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:100
msgid ""
"*buffer* is any array-like (list, numpy array, etc.).  A 1D buffer gives a "
"single-component array; a 2D buffer with shape ``(N, M)`` gives an ``M``-"
"component array (the buffer is flattened internally)."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:104
msgid ""
"The data is converted to a VTK buffer via ``numpy_to_vtk`` (zero-copy when "
"the dtype already matches) and ``ConstructBackend`` is called."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:98
msgid "Set strided backend parameters."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:100
msgid ""
"*buffer* is a ``vtkAbstractBuffer`` (e.g. obtained via ``array."
"GetBuffer()``).  The C++ side stores the buffer with reference counting so "
"the vtkBuffer object stays alive."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:104
msgid ""
"If the buffer was created by ``numpy_to_vtk`` (zero-copy), the underlying "
"numpy array reference is also preserved here so that the raw memory remains "
"valid."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:106
msgid "Return the underlying buffer as a flat numpy array (zero-copy)."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:108
msgid "Returns None if no buffer is accessible (raw-pointer construction)."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:114
msgid "Return the stride of the strided backend."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:122
msgid "Return the offset of the strided backend."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:146
msgid "Return the array as a numpy ndarray (zero-copy when possible)."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:154
msgid "Return a numpy view using strides (zero-copy when possible)."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:156
msgid ""
"When the underlying buffer is accessible, creates a strided numpy view that "
"maps directly to the buffer memory.  Falls back to DeepCopy only when the "
"buffer is not accessible from Python."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:162
msgid "Override C-level buffer protocol to return strided view."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:170
msgid "Handle numpy ufuncs by materializing."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:178
msgid "Dispatch numpy functions via override registry."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:186
msgid "Index into the strided array."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_strided_array.py:188
msgid ""
"Scalar index: direct lookup via GetComponent/GetTuple. Everything else: "
"delegates to the numpy strided view."
msgstr ""
