#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:7
msgid ""
"VTKStructuredPointArray — lazy numpy-compatible wrapper for structured "
"points."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:9
msgid ""
"This module provides VTKStructuredPointArray and VTKStructuredAxisArray "
"classes that lazily represent the point coordinates of vtkImageData and "
"vtkRectilinearGrid datasets without materializing the full (N, 3) array."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:13
msgid ""
"For a grid with dimensions (nx, ny, nz), only O(nx + ny + nz) storage is "
"needed instead of O(nx * ny * nz * 3).  Ufuncs and scalar arithmetic operate "
"per-axis and stay lazy.  Reductions (sum, min, max, mean) use optimized "
"O(nx+ny+nz) formulas."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:18
#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:329
msgid ""
"VTK uses Fortran ordering where i increases fastest:     flat_idx = i + j * "
"nx + k * nx * ny"
msgstr ""

