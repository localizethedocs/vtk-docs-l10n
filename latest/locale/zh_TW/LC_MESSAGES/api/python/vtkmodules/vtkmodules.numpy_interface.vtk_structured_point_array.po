#: ../../../api/python/vtkmodules/vtkmodules.numpy_interface.vtk_structured_point_array.md:585
msgid ""
"Bases: {py:obj}`vtkmodules.numpy_interface._vtk_array_mixin."
"VTKDataArrayMixin`"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:590
msgid ""
"This mixin is automatically applied to all ``vtkStructuredPointArray`` "
"instantiations (e.g. ``vtkStructuredPointTypeFloat64Array``).  It provides "
"``__array__``, ``__buffer__``, indexing, and basic numpy protocol so that "
"structured point arrays returned by VTK are directly usable with numpy."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:596
msgid ""
"The mixin retrieves axis coordinate arrays directly from the C++ backend via "
"``GetXCoordinates()``, ``GetYCoordinates()``, and ``GetZCoordinates()``, "
"enabling lazy per-axis operations and O(nx+ny+nz) reductions.  When no "
"backend is available, it materializes via ``DeepCopy`` to an AOS array."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:601
msgid "Get the X, Y, Z coordinate arrays directly from the backend."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:603
msgid ""
"Returns a list of 3 numpy arrays [X, Y, Z], or None if the backend has not "
"been constructed yet."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:609
msgid "Get grid dimensions from axis arrays."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:617
msgid "Check if a non-identity direction matrix is being used."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:641
msgid "Materialize the full array as a numpy ndarray."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:643
msgid ""
"When axis arrays are available and no direction matrix is used, materializes "
"via meshgrid (efficient).  Otherwise, uses DeepCopy to an AOS array."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:649
msgid "Return the full (N, 3) array as a numpy ndarray."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:905
msgid ""
"Templates that only have vtkType-based instantiations (e.g. vtkTypeFloat64) "
"need aliases under the native IA64 mangled names (e.g. _IdE for double) so "
"that the Python template subscript notation template['float64'] can find "
"them."
msgstr ""
