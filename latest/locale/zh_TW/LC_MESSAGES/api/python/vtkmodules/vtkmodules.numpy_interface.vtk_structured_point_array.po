#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:152
msgid ""
"For a structured grid with dims (nx, ny, nz), there are only nx unique X "
"values, ny unique Y values, and nz unique Z values.  This class stores just "
"the unique values and expands them lazily when needed."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:156
msgid "Repeat patterns (Fortran ordering, i fastest):"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:157
msgid "Axis 0 (X): X[i] appears at indices where flat_idx % nx == i"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:158
msgid "Axis 1 (Y): Y[j] appears at indices where (flat_idx // nx) % ny == j"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_structured_point_array.py:159
msgid "Axis 2 (Z): Z[k] appears at indices where flat_idx // (nx * ny) == k"
msgstr ""

#: ../../../api/python/vtkmodules/vtkmodules.numpy_interface.vtk_structured_point_array.md:151
#: ../../../api/python/vtkmodules/vtkmodules.numpy_interface.vtk_structured_point_array.md:322
#: ../../../api/python/vtkmodules/vtkmodules.numpy_interface.vtk_structured_point_array.md:590
msgid "Initialization"
msgstr ""

