msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/util/data_array_selection.py:9
msgid ""
"Makes vtkDataArraySelection behave like a Python dictionary (str -> bool)::"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/util/data_array_selection.py:11
msgid ""
"sel = reader.GetPointDataArraySelection()\n"
"sel[\"Pressure\"]              # True/False\n"
"sel[\"Pressure\"] = True       # EnableArray\n"
"sel[\"Pressure\"] = False      # DisableArray\n"
"\"Pressure\" in sel            # True\n"
"len(sel)                     # number of arrays\n"
"del sel[\"Pressure\"]          # RemoveArrayByName\n"
"for name in sel: ...         # iterate array names\n"
msgstr ""

