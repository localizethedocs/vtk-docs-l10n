#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_affine_array.py:7
msgid "VTKAffineArray — numpy-compatible mixin for vtkAffineArray."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_affine_array.py:9
msgid ""
"This module provides the VTKAffineArray mixin class and registers overrides "
"for all vtkAffineArray instantiations so that affine arrays coming from VTK "
"automatically have numpy-compatible operations."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_affine_array.py:13
msgid ""
"vtkAffineArray computes values using an affine function:     value = slope * "
"index + intercept"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_affine_array.py:16
msgid ""
"Arithmetic with scalars produces new affine arrays (staying lazy). "
"Reductions like sum, mean, min, max, std use closed-form formulas. The full "
"array is never materialized unless explicitly requested."
msgstr ""

