#: ../../../supported_data_formats.md:1
msgid "Supported Data Formats"
msgstr ""

#: ../../../supported_data_formats.md:3
msgid ""
"Below is a list of all available readers and writers in VTK sorted by "
"extension.  Note that for the same extension it could be more than one "
"matching reader/writer since the same extensions are often used across "
"different formats. The list is generated based on a [yaml](./"
"supported_data_formats.yaml) file that contains all the relevant information."
msgstr ""

#: ../../../supported_data_formats.md:9
msgid ""
"To enable a reader/writer you need to enable the associated module during "
"configuration:"
msgstr ""

#: ../../../supported_data_formats.md:10
msgid "cmake -DVTK_MODULE_ENABLE_<module name>=WANT ...\n"
msgstr ""

#: ../../../supported_data_formats.md:13
msgid "or setting the flag value via `ccmake/cmake-qt`."
msgstr ""

#: ../../../supported_data_formats.md:15
msgid ""
"For example to enable `vtkPNGWriter` which belongs to {bdg-primary-line}"
"`VTK::IOImage`"
msgstr ""

#: ../../../supported_data_formats.md:17
msgid "cmake -DVTK_MODULE_ENABLE_VTK_IOImage=WANT ...\n"
msgstr ""

#: ../../../supported_data_formats.md:21
msgid ""
"For more details on enabling module see the module system [api](api/cmake/"
"ModuleSystem.md#enabling-modules-for-build)."
msgstr ""

#: ../../../supported_data_formats.md:24
msgid "the list is incomplete, this is work in progress"
msgstr ""

