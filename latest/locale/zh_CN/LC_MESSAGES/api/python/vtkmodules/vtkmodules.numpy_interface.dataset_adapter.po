#: ../../../api/python/vtkmodules/vtkmodules.numpy_interface.dataset_adapter.md:1
msgid "{py:mod}`vtkmodules.numpy_interface.dataset_adapter`"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/dataset_adapter.py:7
msgid ""
"This module provides classes that allow Numpy-type access to VTK datasets "
"and arrays. This is best described with some examples."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/dataset_adapter.py:10
msgid "To normalize a VTK array:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/dataset_adapter.py:12
msgid ""
"from vtkmodules.vtkImagingCore vtkRTAnalyticSource import vtkmodules."
"numpy_interface.dataset_adapter as dsa import vtkmodules.numpy_interface."
"algorithms as algs"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/dataset_adapter.py:16
msgid ""
"rt = vtkRTAnalyticSource() rt.Update() image = dsa.WrapDataObject(rt."
"GetOutput()) rtdata = image.PointData['RTData'] rtmin = algs.min(rtdata) "
"rtmax = algs.max(rtdata) rtnorm = (rtdata - rtmin) / (rtmax - rtmin) image."
"PointData.append(rtnorm, 'RTData - normalized') print image.GetPointData()."
"GetArray('RTData - normalized').GetRange()"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/dataset_adapter.py:26
msgid "To calculate gradient:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/dataset_adapter.py:28
msgid "grad= algs.gradient(rtnorm)"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/dataset_adapter.py:30
msgid "To access subsets:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/dataset_adapter.py:32
msgid ""
"grad[0:10] VTKArray([[ 0.10729134,  0.03763443,  0.03136338],        "
"[ 0.02754352,  0.03886006,  0.032589  ],        [ 0.02248248,  0.04127144,  "
"0.03500038],        [ 0.02678365,  0.04357527,  0.03730421],        "
"[ 0.01765099,  0.04571581,  0.03944477],        [ 0.02344007,  0.04763837,  "
"0.04136734],        [ 0.01089381,  0.04929155,  0.04302051],        "
"[ 0.01769151,  0.05062952,  0.04435848],        [ 0.002764  ,  0.05161414,  "
"0.04534309],        [ 0.01010841,  0.05221677,  0.04594573]])"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/dataset_adapter.py:44
msgid ""
"grad[:, 0] VTKArray([ 0.10729134,  0.02754352,  0.02248248, ..., "
"-0.02748174,        -0.02410045,  0.05509736])"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/dataset_adapter.py:48
msgid ""
"All of this functionality is also supported for composite datasets even "
"though their data arrays may be spread across multiple datasets. We have "
"implemented a VTKCompositeDataArray class that handles many Numpy style "
"operators and is supported by all algorithms in the algorithms module."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/dataset_adapter.py:54
msgid ""
"This module also provides an API to access composite datasets. For example:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/dataset_adapter.py:57
msgid ""
"from vtkmodules.vtkCommonDataModel import vtkMultiBlockDataSet mb = "
"vtkMultiBlockDataSet() mb.SetBlock(0, image.VTKObject) mb.SetBlock(1e, image."
"VTKObject) cds = dsa.WrapDataObject(mb) for block in cds:     print block"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/dataset_adapter.py:65
msgid ""
"Note that this module implements only the wrappers for datasets and arrays. "
"The classes implement many useful operators. However, to make best use of "
"these classes, take a look at the algorithms module."
msgstr ""

