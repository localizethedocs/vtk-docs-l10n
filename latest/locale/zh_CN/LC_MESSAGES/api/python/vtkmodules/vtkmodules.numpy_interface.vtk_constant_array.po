#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:100
msgid "Create with bracket notation and positional arguments::"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:102
msgid ""
"from vtkmodules.vtkCommonCore import vtkConstantArray\n"
"\n"
"# 1-component, 1 million tuples, all 5.0\n"
"a = vtkConstantArray[numpy.float64](1000000, 5.0)\n"
"\n"
"# 3-component, 100 tuples, all 5.0\n"
"b = vtkConstantArray[numpy.float64]((100, 3), 5.0)\n"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:110
msgid ""
"Available dtypes: ``'float32'``, ``'float64'``, ``'int8'``, ``'int16'``, "
"``'int32'``, ``'int64'``, ``'uint8'``, ``'uint16'``, ``'uint32'``, "
"``'uint64'``."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:114
