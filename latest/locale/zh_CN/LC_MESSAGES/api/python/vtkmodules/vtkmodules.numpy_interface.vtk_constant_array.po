"(INFO/1) Duplicate implicit target name: \"dataset integration\"."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:163
msgid ""
"Constant arrays retrieved from a VTK dataset (via ``data_model``) "
"automatically carry ``dataset`` and ``association`` metadata::"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:166
msgid ""
"arr = polydata.point_data[\"my_constant_array\"]\n"
"print(arr.value)       # the constant\n"
"print(arr.dataset)     # the owning vtkPolyData\n"
msgstr ""

