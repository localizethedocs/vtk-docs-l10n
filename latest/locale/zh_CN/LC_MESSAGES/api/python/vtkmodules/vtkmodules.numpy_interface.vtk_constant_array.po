#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:7
msgid "VTKConstantArray — numpy-compatible mixin for vtkConstantArray."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:9
msgid ""
"This module provides the VTKConstantArray mixin class and registers "
"overrides for all vtkConstantArray instantiations so that constant arrays "
"coming from VTK automatically have numpy-compatible operations."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:13
msgid ""
"Arithmetic between constant arrays produces new constant arrays; mixed "
"operations with real arrays return VTKAOSArray results.  The constant value "
"is never materialized into a full array unless explicitly requested."
msgstr ""

