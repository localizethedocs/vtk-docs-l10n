msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:143
msgid "Constant arrays implement the numpy array protocol:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:145
msgid ""
"``numpy.asarray(arr)`` materializes the full array via ``numpy.full()``."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:147
msgid ""
"``numpy.sum(arr)``, ``numpy.mean(arr)``, etc. are intercepted and computed "
"in O(1)."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:149
msgid ""
"Ufuncs (``numpy.sin``, ``numpy.sqrt``, etc.) substitute the scalar value."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:151
msgid ""
"Unoptimized numpy functions trigger a warning and fall back to "
"materialization."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:154
msgid ""
"Indexing/home/runner/work/vtk-docs-l10n/vtk-docs-l10n/out/repo/Wrapping/"
