#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:116
msgid ""
"value : scalar     The constant value stored by the array. shape : tuple of "
"int     ``(ntuples,)`` for 1-component, ``(ntuples, ncomps)`` otherwise. "
"dtype : numpy.dtype     The element data type. dataset : vtkDataSet or "
"None     The owning VTK dataset, when the array is attached to one. "
"association : int or None     The attribute association (POINT, CELL, etc.)."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:127
