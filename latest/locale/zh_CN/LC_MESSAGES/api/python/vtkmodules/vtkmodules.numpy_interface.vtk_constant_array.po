msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:91
msgid ""
"shape : int or tuple of int, optional     Number of tuples (single int or 1-"
"tuple), or ``(ntuples, ncomps)``     for a multi-component array.  When "
"omitted, creates an empty array     with zero tuples that can be resized "
"later with the C++ API. value : scalar, optional     The constant value for "
"every element.  Default is ``0``."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_constant_array.py:98
msgid ""
"Construction/home/runner/work/vtk-docs-l10n/vtk-docs-l10n/out/repo/Wrapping/"
