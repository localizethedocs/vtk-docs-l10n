#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_aos_array.py:125
msgid ""
"The internal VTK buffer is shared with numpy — no data is copied when you "
"read array values::"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_aos_array.py:128
msgid ""
"arr = polydata.point_data[\"Normals\"]\n"
"normals = np.asarray(arr)   # zero-copy view\n"
"normals[:, 2] = 0           # modifies VTK data in place\n"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_aos_array.py:132
msgid ""
"Memory Safety/home/runner/work/vtk-docs-l10n/vtk-docs-l10n/out/repo/Wrapping/"
