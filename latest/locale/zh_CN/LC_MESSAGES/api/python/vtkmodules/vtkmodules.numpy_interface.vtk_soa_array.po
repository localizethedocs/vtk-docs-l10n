#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_soa_array.py:7
msgid "VTKSOAArray — numpy-compatible mixin for vtkSOADataArrayTemplate."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/numpy_interface/vtk_soa_array.py:9
msgid ""
"This module provides the VTKSOAArray mixin class and registers overrides for "
"all vtkSOADataArrayTemplate instantiations so that SOA arrays coming from "
"VTK automatically have numpy-compatible operations.  Per-component buffers "
"are exposed as zero-copy numpy arrays; when a contiguous AOS array is "
"needed, the wrapper materialises one on the fly via ``numpy.column_stack``."
msgstr ""

