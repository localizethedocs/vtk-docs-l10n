#: ../../../api/python/vtkmodules/vtkmodules.generate_pyi.md:1
msgid "{py:mod}`vtkmodules.generate_pyi`"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/generate_pyi.py:7
msgid ""
"This program will generate .pyi files for all the VTK modules in the "
"\"vtkmodules\" package (or whichever package you specify). These files are "
"used for type checking and autocompletion in some Python IDEs."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/generate_pyi.py:12
msgid ""
"The VTK modules must be in Python's path when you run this script. Options "
"are as follows:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/generate_pyi.py:15
msgid ""
"-p PACKAGE    The package to generate .pyi files for [vtkmodules]  -o "
"OUTPUT     The output directory [default is the package directory]  -e "
"EXT        The file suffix [.pyi]  -i IMPORTER   The static module importer "
"(for static builds only)  -h HELP"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/generate_pyi.py:21
msgid ""
"With no arguments, the script runs with the defaults (the .pyi files are put "
"inside the existing vtkmodules package).  This is equivalent to the "
"following:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/generate_pyi.py:25
msgid "python -m vtkmodules.generate_pyi -p vtkmodules\n"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/generate_pyi.py:27
msgid "To put the pyi files somewhere else, perhaps with a different suffix:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/generate_pyi.py:29
msgid "python -m vtkmodules.generate_pyi -o /path/to/vtkmodules -e .pyi\n"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/generate_pyi.py:31
msgid "To generate pyi files for just one or two modules:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/generate_pyi.py:33
msgid ""
"python -m vtkmodules.generate_pyi -p vtkmodules vtkCommonCore "
"vtkCommonDataModel\n"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/generate_pyi.py:35
msgid "To generate pyi files for your own modules in your own package:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/generate_pyi.py:37
msgid ""
"python -m vtkmodules.generate_pyi -p mypackage mymodule [mymodule2 ...]\n"
msgstr ""

