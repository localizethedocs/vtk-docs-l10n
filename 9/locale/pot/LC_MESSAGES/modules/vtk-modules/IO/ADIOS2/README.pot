msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:16
msgid "##Public VTK classes:"
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:18
msgid ""
"**vtkADIOS2ImageCoreReader.h/.cxx** : a generic multiblock reader for image "
"data developed at Kitware Inc. It will use existing arrays to populate "
"dimension of the image, adding timesteps info, point and cell data "
"accordingly. No predefined schema is needed. It can work in serial or MPI "
"mode."
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:20
msgid ""
"**vtkADIOS2VTXReader .h/.cxx** : multiblock reader for ImageData and "
"UnstructuredData types using VTK ADIOS2 Readers (VTX) implementation "
"developed at Oak Ridge National Laboratory (ORNL). Reads bp files/streams "
"with a vtk.xml attribute schema that uses the [VTK XML file formats schemas]"
"(https://vtk.org/wp-content/uploads/2015/04/file-formats.pdf). For more "
"comprehensive documentation refer [to this section in the ADIOS2 User Guide.]"
"(https://adios2.readthedocs.io/en/latest/ecosystem/visualization.html)"
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:22
msgid "**VTX: VTK ADIOS2 READERS**"
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:24
msgid ""
"Developed at Oak Ridge National Laboratory. Reads node (image and "
"unstructured) and cell (unstructured) centered data."
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:26
msgid ""
"**common/VTXDataArray .h/.cxx** : wrapper around vtkDataArray with adios2-"
"related relevant information"
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:29
msgid ""
"**common/VTXHelper .h/.inl/.txx/.cxx** : collection of helper functions used "
"privately in *.cxx"
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:32
msgid "**common/VTXTypes.h** : header only types definitions including MACROS"
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:35
msgid ""
"**VTXSchemaManager** : reusable class that manages a reader that is a "
"derived type of VTXSchema"
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:38
msgid ""
"**schema/VTXSchema .h/.txx/.cxx** : abstract base class for supported schema"
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:39
msgid "schema/vtk/VTXvtkBase : Base class for VTK formats"
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:40
msgid "schema/vtk/VTXvtkVTI : ImageData VTK format"
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:41
msgid "schema/vtk/VTXvtkVTU : Unstructured VTK format"
msgstr ""
