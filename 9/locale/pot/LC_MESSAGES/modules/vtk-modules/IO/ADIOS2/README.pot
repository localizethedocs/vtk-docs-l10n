msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:5
msgid ""
"Provide readers to data produced by the Adaptable Input Output System "
"version 2, [ADIOS2](https://adios2.readthedocs.io/en/latest/)."
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:7
msgid "Currently used on Paraview Application Server Manager development"
msgstr ""

