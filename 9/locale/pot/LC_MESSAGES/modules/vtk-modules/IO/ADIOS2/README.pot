msgid "Extensions:"
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:11
msgid ".h = header declaration"
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:12
msgid ".inl = generic inline template implementations"
msgstr ""

#: ../../../modules/vtk-modules/IO/ADIOS2/README.md:13
