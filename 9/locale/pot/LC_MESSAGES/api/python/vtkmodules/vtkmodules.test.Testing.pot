#: ../../../api/python/vtkmodules/vtkmodules.test.Testing.md:1
msgid "{py:mod}`vtkmodules.test.Testing`"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:7
msgid ""
"This module attempts to make it easy to create VTK-Python unittests.  The "
"module uses unittest for the test interface.  For more documentation on what "
"unittests are and how to use them, please read these:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:12
msgid "https://docs.python.org/3/library/unittest.html"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:14
msgid "https://diveintopython3.net/unit-testing.html"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:17
msgid ""
"This VTK-Python test module supports image based tests with multiple images "
"per test suite and multiple images per individual test as well. It also "
"prints information appropriate for CDash (https://www.cdash.org/)."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:22
msgid ""
"This module defines several useful classes and functions to make writing "
"tests easy.  The most important of these are:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:25
msgid ""
"class vtkTest:    Subclass this for your tests.  It also has a few useful "
"internal    functions that can be used to do some simple blackbox testing."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:29
msgid ""
"compareImage(renwin, img_fname, threshold=0.05):    Compares renwin with "
"image and generates image if it does not    exist.  The threshold determines "
"how closely the images must match.    The function also handles multiple "
"images and finds the best    matching image."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:35
msgid ""
"compareImageWithSavedImage(src_img, img_fname, threshold=0.05):    Compares "
"given source image (in the form of a vtkImageData) with    saved image and "
"generates the image if it does not exist.  The    threshold determines how "
"closely the images must match.  The    function also handles multiple images "
"and finds the best matching    image."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:42
msgid ""
"getAbsImagePath(img_basename):    Returns the full path to the image given "
"the basic image name."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:45
msgid ""
"main(cases):    Does the testing given a list of tuples containing test "
"classes and    the starting string of the functions used for testing."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:49
msgid ""
"interact():     Interacts with the user if necessary.  The behavior of this "
"is     rather trivial and works best when using Tkinter.  It does not do     "
"anything by default and stops to interact with the user when given     the "
"appropriate command line arguments."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:55
msgid ""
"isInteractive():     If interact() is not good enough, use this to find if "
"the mode is     interactive or not and do whatever is necessary to generate "
"an     interactive view."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:60
msgid "Examples:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:62
msgid ""
"The best way to learn on how to use this module is to look at a few   "
"examples.  The end of this file contains a trivial example.  Please   also "
"look at the following examples:"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:66
msgid ""
