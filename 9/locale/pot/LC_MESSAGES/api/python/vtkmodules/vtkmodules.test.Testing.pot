msgid "{py:obj}`compareImage <vtkmodules.test.Testing.compareImage>`"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:60
#: ../../../../../Wrapping/Python/vtkmodules/test/Testing.py:348
msgid ""
"Compares renwin's (a vtkRenderWindow) contents with the image file whose "
"name is given in the second argument.  If the image file does not exist the "
"image is generated and stored.  If not the image in the render window is "
"compared to that of the figure. This function also handles multiple images "
"and finds the best matching image."
msgstr ""

