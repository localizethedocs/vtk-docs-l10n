msgid "Image data with ghost cells and points:"
msgstr ""

#: ../../../../release/_9.1-stripped.md:559
msgid "![ImageData-Ghost-Arrays](imgs/9.1/TestGPURayCastVolumeGhostArrays.png)"
msgstr ""

#: ../../../../release/_9.1-stripped.md:559
msgid "ImageData-Ghost-Arrays"
msgstr ""

#: ../../../../release/_9.1-stripped.md:561
msgid ""
"Volume rendering may now use independent scalar arrays for the `x` and `y` "
"dimensions of 2D transfer functions."
msgstr ""

