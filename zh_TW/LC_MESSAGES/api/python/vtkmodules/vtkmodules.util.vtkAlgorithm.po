#: ../../../../../Wrapping/Python/vtkmodules/util/vtkAlgorithm.py:147
msgid ""
"class HDF5Source(VTKPythonAlgorithmBase):     def __init__(self):         "
"VTKPythonAlgorithmBase.__init__(self,             nInputPorts=0,             "
"nOutputPorts=1, outputType='vtkImageData')"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/util/vtkAlgorithm.py:153
msgid ""
"def RequestInformation(self, request, inInfo, outInfo):\n"
"    f = h5py.File(\"foo.h5\", 'r')\n"
"    dims = f['RTData'].shape[::-1]\n"
"    info = outInfo.GetInformationObject(0)\n"
"    info.Set(vtkmodules.vtkCommonExecutionModel."
"vtkStreamingDemandDrivenPipeline.WHOLE_EXTENT(),\n"
"        (0, dims[0]-1, 0, dims[1]-1, 0, dims[2]-1), 6)\n"
"    return 1\n"
"\n"
"def RequestData(self, request, inInfo, outInfo):\n"
"    f = h5py.File(\"foo.h5\", 'r')\n"
"    data = f['RTData'][:]\n"
"    output = dsa.WrapDataObject(vtkmodules.vtkCommonDataModel.vtkImageData."
"GetData(outInfo))\n"
"    output.SetDimensions(data.shape)\n"
"    output.PointData.append(data.flatten(), 'RTData')\n"
"    output.PointData.SetActiveScalars('RTData')\n"
"    return 1\n"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/util/vtkAlgorithm.py:170
msgid "alg = HDF5Source()"
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/util/vtkAlgorithm.py:172
msgid ""
"cf = vtkmodules.vtkFiltersCore.vtkContourFilter() cf.SetInputConnection(alg."
"GetOutputPort()) cf.Update()"
msgstr ""

