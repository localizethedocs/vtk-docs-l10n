#: ../../../../../Wrapping/Python/vtkmodules/gtk/GtkGLExtVTKRenderWindow.py:9
msgid ""
"This provides a VTK widget for pyGtk.  This embeds a vtkRenderWindow   "
"inside a GTK widget.  This is based on GtkVTKRenderWindow.py."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/gtk/GtkGLExtVTKRenderWindow.py:12
msgid ""
"The extensions here allow the use of gtkglext rather than gtkgl and   "
"pygtk-2 rather than pygtk-0.  It requires pygtk-2.0.0 or later."
msgstr ""

#: ../../../../../Wrapping/Python/vtkmodules/gtk/GtkGLExtVTKRenderWindow.py:15
msgid "There is a working example at the bottom."
msgstr ""

