msgstr ""

#: ../../../modules/vtk-modules/Rendering/WebGPU/README.md:22
msgid ""
"This module uses Dawn's C++ WebGPU implementation on desktop and the "
"`emdawnwebgpu` subcomponent for wasm (automatically fetched by emscripten "
"with `--use-port=emdawnwebgpu` flag)"
msgstr ""

#: ../../../modules/vtk-modules/Rendering/WebGPU/README.md:24
msgid "Cloning and Building Dawn"
msgstr ""

#: ../../../modules/vtk-modules/Rendering/WebGPU/README.md:26
msgid ""
"Dawn should be built at tag [v20250621.085109](https://github.com/google/"
"dawn/tree/v20250621.085109)."
msgstr ""

#: ../../../modules/vtk-modules/Rendering/WebGPU/README.md:28
msgid ""
"# Clone the repo and checkout the required version\n"
"git clone https://github.com/google/dawn dawn && cd dawn\n"
"git checkout v20250621.085109\n"
msgstr ""

#: ../../../modules/vtk-modules/Rendering/WebGPU/README.md:34
msgid "Build Dawn with `CMake` and `Ninja`"
msgstr ""

#: ../../../modules/vtk-modules/Rendering/WebGPU/README.md:36
msgid ""
"cmake -S . -B out/Debug -GNinja -DDAWN_FETCH_DEPENDENCIES=ON -"
"DDAWN_ENABLE_INSTALL=ON\n"
"cmake --build out/Debug\n"
"cmake --install out/Debug --prefix /path/to/install/dawn\n"
msgstr ""

#: ../../../modules/vtk-modules/Rendering/WebGPU/README.md:42
msgid "Configuring and Building VTK"
msgstr ""

#: ../../../modules/vtk-modules/Rendering/WebGPU/README.md:44
msgid "When configuring VTK's build for wasm, configure with:"
msgstr ""

#: ../../../modules/vtk-modules/Rendering/WebGPU/README.md:46
msgid ""
"cmake \\\n"
"-S /path/to/vtk/src \\\n"
"-B /path/to/vtk/build \\\n"
"-GNinja \\\n"
"-DVTK_ENABLE_WEBGPU=ON \\\n"
"-DVTK_BUILD_TESTING=ON\n"
"\n"
"cmake --build\n"
msgstr ""

#: ../../../modules/vtk-modules/Rendering/WebGPU/README.md:57
msgid "When building on desktop (x86_64/aarch64), configure with:"
msgstr ""

#: ../../../modules/vtk-modules/Rendering/WebGPU/README.md:59
msgid ""
"cmake \\\n"
"-S /path/to/vtk/src \\\n"
"-B /path/to/vtk/build \\\n"
"-GNinja \\\n"
"-DVTK_ENABLE_WEBGPU=ON \\\n"
"-DDawn_DIR=/path/to/where/dawn/is/installed/lib/cmake/Dawn \\\n"
"-DVTK_BUILD_TESTING=ON\n"
"\n"
"cmake --build\n"
msgstr ""

