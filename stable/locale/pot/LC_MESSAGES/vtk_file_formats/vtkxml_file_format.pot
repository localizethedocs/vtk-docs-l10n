#: ../../../vtk_file_formats/vtkxml_file_format.md:794
msgid ""
"Below is another unstructured grid example, which uses polyhedron cell types."
msgstr ""

#: ../../../vtk_file_formats/vtkxml_file_format.md:796
msgid "UnstructuredGrid Example with Polyhedron Cell Types"
msgstr ""

#: ../../../vtk_file_formats/vtkxml_file_format.md:801
msgid "Here we see a few additional ``DataArray`` types:"
msgstr ""

#: ../../../vtk_file_formats/vtkxml_file_format.md:803
msgid ""
"The ``faces`` array specifies the faces of all the cells. The description "
"for each cell must first specify the total number of faces, then list each "
"face, starting with the number of points and followed by the point IDs."
msgstr ""

#: ../../../vtk_file_formats/vtkxml_file_format.md:804
msgid ""
"cell0_nFaces\n"
"cell0_face0_npts p0 p1 ...\n"
"cell0_face1_npts p0 p1 ...\n"
"...\n"
"\n"
"cell1_nFaces\n"
"cell1_face0_npts p0 p1 ...\n"
"cell1_face1_npts p0 p1 ...\n"
"...\n"
"\n"
"cell2_nFaces\n"
"...\n"
msgstr ""

#: ../../../vtk_file_formats/vtkxml_file_format.md:819
msgid ""
"``faceoffsets`` contains the offsets into the ``faces`` array for the end of "
"each cell."
msgstr ""

#: ../../../vtk_file_formats/vtkxml_file_format.md:821
msgid ""
"``connectivity`` in this case lists all unique point IDs referenced in each "
"cell."
msgstr ""

#: ../../../vtk_file_formats/vtkxml_file_format.md:823
msgid ""
"``offsets`` describes where each cell entry ends in the ``connectivity`` "
"array."
msgstr ""

