msgstr ""

#: ../../../../release/_9.2-stripped.md:332
msgid "`vtkSuperquadricSource` now creates pieces using multiple threads."
msgstr ""

#: ../../../../release/_9.2-stripped.md:333
msgid ""
"Particle traces now support `vtkDataObjectTree` objects to define seed "
"points rather than only `vtkDataSet` objects."
msgstr ""

#: ../../../../release/_9.2-stripped.md:335
msgid "`vtkStreamTracer` now uses SMP when multiprocessing is not in use."
msgstr ""

#: ../../../../release/_9.2-stripped.md:336
msgid "`vtkStreamTracer` performance and quality have been improved."
msgstr ""

#: ../../../../release/_9.2-stripped.md:337
