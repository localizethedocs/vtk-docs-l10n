#: ../../../../release/_9.3-stripped.md:677
msgid "To use this new feature in python, you must first run:"
msgstr ""

#: ../../../../release/_9.3-stripped.md:678
msgid "import vtkmodules.util.pickle_support\n"
msgstr ""

#: ../../../../release/_9.3-stripped.md:681
msgid ""
"Once you have imported the module the pickling of data objects is "
"straightforward:"
msgstr ""

#: ../../../../release/_9.3-stripped.md:682
msgid ""
"from vtkmodules.vtkFiltersSources import vtkSphereSource\n"
"import vtkmodules.util.pickle_support\n"
"import pickle\n"
"\n"
"sphereSrc = vtkSphereSource()\n"
"sphereSrc.Update()\n"
"\n"
"pickled = pickle.dumps(sphereSrc.GetOutput())\n"
"unpickled = pickle.loads(pickled)\n"
"\n"
"print(unpickled)\n"
msgstr ""

