"processIdsGenerator->GeneratePointDataOff();\n"
"processIdsGenerator->GenerateCellDataOn();\n"
"processIdsGenerator->Update();\n"
"\n"
"vtkDataSet* pidGeneratorOutput = processIdsGenerator->GetOutput();\n"
