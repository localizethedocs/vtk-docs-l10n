#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:1
msgid "Replace unsafe c from/to string functions"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:3
msgid ""
"VTK has been using a set of either unsafe or slow C/C++ functions to convert "
"numbers to string or vice versa. The exhaustive list of functions is given "
"below. And all of them have been replaced with safer alternatives/faster "
"alternatives provided by scnlib, fmt, and fast_float libraries and exposed "
"though the vtk:: namespace."
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:7
msgid ""
"C/C++ has the following functions to convert one/many char or string to a "
"number."
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:9
msgid "atof, atoi, atol, atoll,"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:10
msgid ""
"std::stof, std::stod, std::stold, std::stoi, std::stol, std::stoll, std::"
"stoul, std::stoull"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:11
msgid ""
"std::strtof, std::strtod, std::strtold, std::strtol, std::strtoll/_strtoi64, "
"std::strtoul, std::strtoull"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:13
msgid "sscanf, sscanf_s, vsscanf, vsscanf_s"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:14
msgid ""
"std::from_chars (This is slow because it does not use fast_float under the "
"hood)"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:16
#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:26
#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:40
#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:51
msgid "These functions should be replaced by:"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:18
msgid ""
"vtk::from_chars, vtk::scan_int, vtk::scan_value, if one number needs to be "
"converted"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:19
msgid ""
"vtk::scan, if one/many numbers need to be converted (optionally with a "
"specific format)"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:21
msgid ""
"C/C++ has the following functions to scan one/many numbers from a stdin/file."
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:23
msgid "scanf, scanf_s, vscanf, vscanf_s,"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:24
msgid "fscanf, fscanf_s, vfscanf, vfscanf_s,"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:28
msgid "vtk::scan_value, if one number needs to be converted"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:29
msgid ""
"vtk::input, vtk::scan, if one/many numbers need to be converted (optionally "
"with a specific format)"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:32
msgid ""
"C/C++ has the following functions to convert one/many numbers to a char or "
"string."
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:34
msgid ""
"itoa/_itoa, ltoa/_ltoa, lltoa/_i64toa, ultoa/_ultoa, ulltoa/_ulltoa/_ui64toa"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:35
msgid "sprintf, sprintf_s, vsprintf, vsprintf_s,"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:36
msgid "snprintf, snprintf_s, vsnprintf, vsnprintf_s,"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:37
msgid "strftime"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:38
msgid "std::to_chars, std::to_string"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:42
msgid "vtk::to_chars or vtk::to_string, if one number needs to be converted"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:43
msgid ""
"vtk::format, vtk::format_to, or vtk::format_to_n, if one/many numbers need "
"to be converted with a specific format"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:46
msgid ""
"C/C++ has the following functions to print one/many numbers to stdout/file."
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:48
msgid "printf, printf_s, vprintf, vprintf_s,"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:49
msgid "fprintf, fprintf_s, vfprintf, vfprintf_s,"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:53
msgid "vtk::print, vtk::println"
msgstr ""

#: ../../../release_details/9.6/replace-unsafe-c-from-to-string-functions.md:55
msgid ""
