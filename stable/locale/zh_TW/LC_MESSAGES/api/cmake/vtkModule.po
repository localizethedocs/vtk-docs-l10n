#: ../../../../../CMake/vtkModule.cmake:494
msgid "Scan modules and kits |module|"
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:497
msgid ""
"Once all of the modules and kits files have been found, they are \"scanned\" "
"to determine what modules are enabled or required."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:500
msgid ""
"vtk_module_scan(\n"
"  MODULE_FILES              <file>...\n"
"  [KIT_FILES                <file>...]\n"
"  PROVIDES_MODULES          <variable>\n"
"  [PROVIDES_KITS            <variable>]\n"
"  [REQUIRES_MODULES         <variable>]\n"
"  [REQUEST_MODULES          <module>...]\n"
"  [REJECT_MODULES           <module>...]\n"
"  [UNRECOGNIZED_MODULES     <variable>]\n"
"  [WANT_BY_DEFAULT          <ON|OFF>]\n"
"  [HIDE_MODULES_FROM_CACHE  <ON|OFF>]\n"
"  [ENABLE_TESTS             <ON|OFF|WANT|DEFAULT>])"
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:515
msgid ""
"The ``MODULE_FILES`` and ``PROVIDES_MODULES`` arguments are required. "
"Modules which refer to kits must be scanned at the same time as their kits. "
"This is so that modules may not add themselves to kits declared prior. The "
"arguments are as follows:"
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:519
msgid "``MODULE_FILES``: (Required) The list of module files to scan."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:520
msgid "``KIT_FILES``: The list of kit files to scan."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:521
msgid ""
"``PROVIDES_MODULES``: (Required) This variable will contain the list of "
"modules which are enabled due to this scan."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:523
msgid ""
"``PROVIDES_KITS``: (Required if ``KIT_FILES`` are provided) This variable "
"will contain the list of kits which are enabled due to this scan."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:525
msgid ""
"``REQUIRES_MODULES``: This variable will contain the list of modules "
"required by the enabled modules that were not scanned."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:527
msgid "``REQUEST_MODULES``: The list of modules required by previous scans."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:528
msgid ""
"``REJECT_MODULES``: The list of modules to exclude from the scan. If any of "
"these modules are required, an error will be raised."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:530
msgid ""
"``UNRECOGNIZED_MODULES``: This variable will contain the list of requested "
"modules that were not scanned."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:532
msgid ""
"``WANT_BY_DEFAULT``: (Defaults to ``OFF``) Whether modules should default to "
"being built or not."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:534
msgid ""
"``HIDE_MODULES_FROM_CACHE``: (Defaults to ``OFF``) Whether or not to hide "
"the control variables from the cache or not. If enabled, modules will not be "
"built unless they are required elsewhere."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:537
msgid ""
"``ENABLE_TESTS``: (Defaults to ``DEFAULT``) Whether or not modules required "
"by the tests for the scanned modules should be enabled or not."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:540
msgid "``ON``: Modules listed as ``TEST_DEPENDS`` will be required."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:541
msgid "``OFF``: Test modules will not be considered."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:542
msgid ""
"``WANT``: Test dependencies will enable modules if possible. Note that this "
"has known issues where modules required only via testing may not have their "
"dependencies enabled."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:545
msgid ""
"``DEFAULT``: Test modules will be enabled if their required dependencies are "
"satisfied and skipped otherwise."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:548
msgid ""
"To make error messages clearer, modules passed to ``REQUIRES_MODULES`` and "
"``REJECT_MODULES`` may have a ``_vtk_module_reason_<MODULE>`` variable set "
"to the reason for the module appearing in either argument. For example, if "
"the ``Package::Frobnitz`` module is required due to a ``ENABLE_FROBNITZ`` "
"cache variable:"
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:554
msgid ""
"set(\"_vtk_module_reason_Package::Frobnitz\"\n"
"  \"via the `ENABLE_FROBNITZ` setting\")"
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:559
msgid ""
"Additionally, the reason for the ``WANT_BY_DEFAULT`` value may be provided "
"via the ``_vtk_module_reason_WANT_BY_DEFAULT`` variable."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:565
msgid "Scanning multiple groups of modules"
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:567
msgid ""
"When scanning complicated projects, multiple scans may be required to get "
"defaults set properly. The ``REQUIRES_MODULES``, ``REQUEST_MODULES``, and "
"``UNRECOGNIZED_MODULES`` arguments are meant to deal with this case. As an "
"example, imagine a project with its source code, third party dependencies, "
"as well as some utility modules which should only be built as necessary. "
"Here, the project would perform three scans, one for each \"grouping\" of "
"modules:"
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:574
msgid ""
"# Scan our modules first because we need to know what of the other groups "
"we\n"
"# need.\n"
"vtk_module_find_modules(our_modules \"${CMAKE_CURRENT_SOURCE_DIR}/src\")\n"
"vtk_module_scan(\n"
"  MODULE_FILES      ${our_modules}\n"
"  PROVIDES_MODULES  our_enabled_modules\n"
"  REQUIRES_MODULES  required_modules)\n"
"\n"
"# Scan the third party modules, requesting only those that are necessary, "
"but\n"
"# allowing them to be toggled during the build.\n"
"vtk_module_find_modules(third_party_modules \"${CMAKE_CURRENT_SOURCE_DIR}/"
"third-party\")\n"
"vtk_module_scan(\n"
"  MODULE_FILES            ${third_party_modules}\n"
"  PROVIDES_MODULES        third_party_enabled_modules\n"
"  # These modules were requested by an earlier scan.\n"
"  REQUEST_MODULES         ${required_modules}\n"
"  REQUIRES_MODULES        required_modules\n"
"  UNRECOGNIZED_MODULES    unrecognized_modules)\n"
"\n"
"# These modules are internal and should only be built if necessary. There is "
"no\n"
"# need to support them being enabled independently, so hide them from the\n"
"# cache.\n"
"vtk_module_find_modules(utility_modules \"${CMAKE_CURRENT_SOURCE_DIR}/"
"utilities\")\n"
"vtk_module_scan(\n"
"  MODULE_FILES            ${utility_modules}\n"
"  PROVIDES_MODULES        utility_enabled_modules\n"
"  # These modules were either requested or unrecognized by an earlier scan.\n"
"  REQUEST_MODULES         ${required_modules}\n"
"                          ${unrecognized_modules}\n"
"  REQUIRES_MODULES        required_modules\n"
"  UNRECOGNIZED_MODULES    unrecognized_modules\n"
"  HIDE_MODULES_FROM_CACHE ON)\n"
"\n"
"if (required_modules OR unrecognized_modules)\n"
"  # Not all of the modules we required were found. This should probably "
"error out.\n"
"endif ()"
msgstr ""

