#: ../../../../../CMake/vtkModule.cmake:230
#: ../../../../../CMake/vtkModule.cmake:378
msgid ""
"All values are optional unless otherwise noted. The following arguments are "
"supported:"
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:233
msgid "``NAME``: (Required) The name of the module."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:234
#: ../../../../../CMake/vtkModule.cmake:382
msgid ""
"``LIBRARY_NAME``: The base name of the library file. It defaults to the "
"module name, but any namespaces are removed. For example, a ``NS::Foo`` "
"module will have a default ``LIBRARY_NAME`` of ``Foo``."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:237
msgid ""
"``DESCRIPTION``: (Recommended) Short text describing what the module is for."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:238
msgid ""
"``KIT``: The name of the kit the module belongs to (see ``Kits files`` for "
"more information)."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:240
msgid ""
"``IMPLEMENTABLE``: If present, the module contains logic which supports the "
"autoinit functionality."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:242
msgid ""
"``GROUPS``: Modules may belong to \"groups\" which is exposed as a build "
"option. This allows for enabling a set of modules with a single build option."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:245
msgid ""
"``CONDITION``: Arguments to CMake's ``if`` command which may be used to hide "
"the module for certain platforms or other reasons. If the expression is "
"false, the module is completely ignored."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:248
msgid ""
"``DEPENDS``: A list of modules which are required by this module and modules "
"using this module."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:250
msgid ""
"``PRIVATE_DEPENDS``: A list of modules which are required by this module, "
"but not by those using this module."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:252
msgid ""
"``OPTIONAL_DEPENDS``: A list of modules which are used by this module if "
"enabled; these are treated as ``PRIVATE_DEPENDS`` if they exist."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:254
msgid ""
"``ORDER_DEPENDS``: Dependencies which only matter for ordering. This does "
"not mean that the module will be enabled, just guaranteed to build before "
"this module."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:257
msgid ""
"``IMPLEMENTS``: A list of modules for which this module needs to register "
"with."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:259
msgid "``TEST_DEPENDS``: Modules required by the test suite for this module."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:260
msgid ""
"``TEST_OPTIONAL_DEPENDS``: Modules used by the test suite for this module if "
"available."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:262
msgid ""
"``TEST_LABELS``: Labels to apply to the tests of this module. By default, "
"the module name is applied as a label."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:264
msgid ""
"``EXCLUDE_WRAP``: If present, this module should not be wrapped in any "
"language."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:266
msgid ""
"``INCLUDE_MARSHAL``: If present, this module opts into automatic code "
"generation of (de)serializers. This option requires that the module is not "
"excluded from wrapping with `EXCLUDE_WRAP`."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:269
msgid "``THIRD_PARTY``: If present, this module is a third party module."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:270
msgid "``LICENSE_FILES``: A list of license files to install for the module."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:271
msgid ""
"``SPDX_LICENSE_IDENTIFIER``: A license identifier for SPDX file generation."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:272
msgid ""
"``SPDX_DOWNLOAD_LOCATION``: A download location for the SPDX file generation."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:273
msgid "``SPDX_COPYRIGHT_TEXT``: A copyright text for the SPDX file generation."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:274
#: ../../../../../CMake/vtkModule.cmake:6250
msgid ""
"``SPDX_CUSTOM_LICENSE_FILE``: A relative path to a  single custom license "
"file to include in generated SPDX file."
msgstr ""

#: ../../../../../CMake/vtkModule.cmake:275
#: ../../../../../CMake/vtkModule.cmake:6251
msgid ""
"``SPDX_CUSTOM_LICENSE_NAME``: The name of the single custom license, without "
"the ``LicenseRef-``"
