#: ../../../release_details/9.4/add-support-for-arbitrary-polyhedra-to-Xdmf2.md:1
msgid "Add support for arbitrary polyhedra to Xdmf2."
msgstr ""

#: ../../../release_details/9.4/add-support-for-arbitrary-polyhedra-to-Xdmf2.md:3
msgid ""
"The Xdmf2 reader now works with geometries that contain arbitrary polyhedra; "
"i.e. cells with an arbitrary number and arrangement of faces. The face "
"connectivity is defined explicitly in the geometry description."
msgstr ""

#: ../../../release_details/9.4/add-support-for-arbitrary-polyhedra-to-Xdmf2.md:7
msgid "This replicates the same ability that exists in Xdmf3."
msgstr ""
